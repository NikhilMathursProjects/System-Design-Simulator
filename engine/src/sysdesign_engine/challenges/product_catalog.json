{
    "entities": {
        "product": {"record_kb": 5.0, "keyspace": 200000}
    },
    "apis": {
        "getProduct": {
            "effect": "retrieve", "entity": "product",
            "compute_units": 0.5, "read_units": 1.0
        },
        "updateListing": {
            "effect": "store", "entity": "product",
            "compute_units": 2.0, "write_units": 1.5
        }
    },
    "traffic": {
        "shape": "request_response",
        "rps": 10000,
        "mix": {"getProduct": 0.98, "updateListing": 0.02},
        "key_dist": "zipf(1.3)",
        "unknown_key_pct": 0.01
    },
    "slos": {
        "getProduct": {"p99_ms": 60},
        "updateListing": {"p99_ms": 300},
        "availability": 0.9995,
        "durability": 0.99999,
        "freshness": {"within_s": 60, "pct": 0.99},
        "monthly_budget_usd": 1200
    }
}
